    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH inventory_update AS (\n  UPDATE inventory\n  SET\n    quantity_on_hand = quantity_on_hand - $1,\n    last_updated = NOW()\n  WHERE id = $2\n    AND quantity_on_hand - quantity_reserved - $1 >= 0\n  RETURNING id\n)\nUPDATE event_outbox\nSET event_status = 'PROCESSED'\nWHERE reference_id = $3\n  AND EXISTS (SELECT 1 FROM inventory_update);",
        "options": {
          "queryReplacement": "={{ $json.quantity }}, {{ $json.inventory_id }}, {{ $json.reference_id }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1120,
        144
      ],
      "id": "33bad5e1-0d5f-4d4d-a556-55bd1d2a95e9",
