    {
      "parameters": {
        "jsCode": "// Input: items from previous node\nconst output = [];\n\n// Generate a random BigInt for idempotency\nfunction randomBigInt() {\n  // Generate random number for idempotency\n  return Math.floor(Math.random() * 1e12).toString();\n}\n\nfor (const event of items) {\n  const data = event.json;\n  const eventId = data.id;\n  \n  // Skip if already processed or payload missing\n  if (!data.payload || !Array.isArray(data.payload.items) || data.processed === true) {\n    continue;\n  }\n  \n  const saleNumber = data.payload.sale_number || null;\n  \n  // Loop through each item and create separate output\n  for (const item of data.payload.items) {\n    const packageId = item.package_id;\n    const inventoryId = item.inventory_id ?? null;\n    const quantity = item.quantity;\n    const brandName = item.brand_name ?? null;\n    const genericName = item.generic_name ?? null;\n    const itemLength = data.payload.items.length;\n    \n    output.push({\n      json: {\n        event_type: \"POS_SALE\",\n        event_outbox_id: randomBigInt(),\n        reference: saleNumber,\n        package_id: packageId,\n        inventory_id: inventoryId,\n        line_reference: `${eventId}of${packageId}of${itemLength}`,\n        quantity,\n        direction: \"OUT\",\n        type: \"SALE\",\n        brand_name: brandName,\n        generic_name: genericName,\n        event_id: eventId,\n        reference_id: data.reference_id,\n        created_at: new Date().toISOString(),\n      },\n    });\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
